{
  "compilerOptions": {
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "preserve",
    "moduleResolution": "bundler",
    "target": "ES2018",
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "lib": ["ES2018", "DOM"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
