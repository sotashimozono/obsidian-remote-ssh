# Copy this file to `.env` to override the docker-compose defaults.
# Leave blank to accept the defaults shown below.

# Host port that maps onto the container's sshd (port 22 inside).
# Default 2222.
# HOST_PORT=2222

# Path on the host that becomes the vault root inside the container
# (mounted at /home/obsidian/vault).
# Default: ./vault (sibling of this compose file).
# VAULT_PATH=./vault

# Path on the host whose contents become the obsidian user's
# authorized_keys (one ssh public key per line). Mounted read-only.
# Default: ./authorized_keys
# AUTHORIZED_KEYS_PATH=./authorized_keys

# Path on the host where sshd persists its host keys. First-run
# generates fresh keys here; subsequent runs reuse them so users
# don't TOFU-prompt on every container recreate.
# Default: ./hostkeys
# HOSTKEYS_PATH=./hostkeys
